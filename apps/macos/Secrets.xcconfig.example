// Copy this file to Secrets.xcconfig and fill in your values
// Secrets.xcconfig is git-ignored — never commit real keys
// Place at: apps/macos/Hallowed/Config/Secrets.xcconfig

SUPABASE_URL = https://your-project-ref.supabase.co
SUPABASE_ANON_KEY = <your-supabase-anon-key>

// Google OAuth — macOS client ID for native sign-in, web ID as serverClientID for Supabase
GOOGLE_WEB_CLIENT_ID = <your-google-client-id>.apps.googleusercontent.com
GOOGLE_MACOS_CLIENT_ID = <your-google-client-id>.apps.googleusercontent.com

// Optional: Enables scripture fetch via api.bible (fallback is bible-api.com if omitted)
API_BIBLE_KEY = <your-api-bible-key>
